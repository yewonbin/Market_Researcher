# ─────────────────────────────────────────────────────────────
#  AI 보험 트렌드 리서치 Agent — 환경변수
#  이 파일을 .env 로 복사한 뒤 값을 채우세요:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Google Gemini API (필수, 무료) ────────────────────────────
# 무료 발급: https://aistudio.google.com/apikey  (구글 계정으로 로그인 → "Create API key")
# 무료 등급으로 이 Agent 용량은 충분히 커버됩니다(요금 청구 없음).
GEMINI_API_KEY=

# ── 이메일 발송 (Gmail SMTP) ──────────────────────────────────
# Gmail 은 일반 비밀번호가 아니라 "앱 비밀번호"가 필요합니다.
#   1) Google 계정 > 보안 > 2단계 인증 사용 설정
#   2) https://myaccount.google.com/apppasswords 에서 앱 비밀번호 생성(16자리)
#   3) 아래 SMTP_PASSWORD 에 그 16자리를 입력 (공백 없이)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=prongs0423@gmail.com
SMTP_PASSWORD=                       # Gmail 앱 비밀번호 16자리
EMAIL_FROM=prongs0423@gmail.com
EMAIL_TO=prongs0423@gmail.com        # 여러 명이면 콤마로 구분: a@x.com,b@y.com

# ── Google Sheets 발송 (선택) ────────────────────────────────
# 비워두면 시트 저장은 건너뜁니다.
#   1) Google Cloud Console 에서 서비스 계정 생성 + JSON 키 다운로드
#   2) 그 JSON 파일 경로를 GOOGLE_SERVICE_ACCOUNT_FILE 에 지정
#   3) 대상 스프레드시트를 서비스 계정 이메일에 "편집자"로 공유
#   4) 스프레드시트 URL 의 /d/<여기>/edit 부분이 SHEET_ID
GOOGLE_SERVICE_ACCOUNT_FILE=         # 예) ./service_account.json
SHEET_ID=                            # 예) 1AbC...xyz
SHEET_WORKSHEET=리포트              # 워크시트(탭) 이름
